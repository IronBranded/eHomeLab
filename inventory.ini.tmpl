# =============================================================================
# ECrime Homelab — Ansible Inventory Template
# =============================================================================
# Copy this file:  cp inventory.ini.tmpl inventory.ini
# Then replace all <PLACEHOLDER> values with your actual IPs.
# NEVER commit inventory.ini — it is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# VLAN 10 — Management
# -----------------------------------------------------------------------------
[management]
proxmox        ansible_host=10.0.10.1   ansible_user=root  ansible_port=22
gitea          ansible_host=10.0.10.10  ansible_user=ansible
vault          ansible_host=10.0.10.11  ansible_user=ansible
wireguard      ansible_host=10.0.10.20  ansible_user=ansible

# -----------------------------------------------------------------------------
# VLAN 20 — Analysis
# -----------------------------------------------------------------------------
[sift_remnux]
sift           ansible_host=10.0.20.10  ansible_user=analyst

[tsurugi]
tsurugi        ansible_host=10.0.20.11  ansible_user=analyst

[flare_vm]
# Windows host — uses WinRM not SSH
flarevm        ansible_host=10.0.20.12  ansible_user=analyst
               ansible_connection=winrm
               ansible_winrm_transport=ntlm
               ansible_winrm_server_cert_validation=ignore
               ansible_port=5986

[zeek_suricata]
sensor         ansible_host=10.0.20.31  ansible_user=ansible

[ms_cloud]
# Windows host — uses WinRM
mscloud        ansible_host=10.0.20.40  ansible_user=analyst
               ansible_connection=winrm
               ansible_winrm_transport=ntlm
               ansible_winrm_server_cert_validation=ignore
               ansible_port=5986

[android_forensics]
android        ansible_host=10.0.20.50  ansible_user=analyst

[crypto_tracing]
crypto         ansible_host=10.0.20.60  ansible_user=analyst

# Velociraptor server lives in VLAN 20, managed separately
[velociraptor]
velociraptor   ansible_host=10.0.20.30  ansible_user=ansible

# -----------------------------------------------------------------------------
# VLAN 30 — Detonation (air-gapped — Ansible access via mgmt VLAN bridge only)
# -----------------------------------------------------------------------------
[cape]
cape           ansible_host=10.0.30.10  ansible_user=ansible
               ansible_ssh_common_args='-o ProxyJump=ansible@10.0.10.1'

[inetsim]
inetsim        ansible_host=10.0.30.11  ansible_user=ansible
               ansible_ssh_common_args='-o ProxyJump=ansible@10.0.10.1'

# -----------------------------------------------------------------------------
# VLAN 40 — Intelligence & Case Management
# -----------------------------------------------------------------------------
[thehive]
thehive        ansible_host=10.0.40.20  ansible_user=ansible

[misp]
misp           ansible_host=10.0.40.10  ansible_user=ansible

[opencti]
opencti        ansible_host=10.0.40.11  ansible_user=ansible

[shuffle]
shuffle        ansible_host=10.0.40.22  ansible_user=ansible

# -----------------------------------------------------------------------------
# VLAN 50 — Logging
# -----------------------------------------------------------------------------
[sof_elk]
sofelk         ansible_host=10.0.50.10  ansible_user=ansible

# -----------------------------------------------------------------------------
# VLAN 60 — Evidence NAS
# -----------------------------------------------------------------------------
[nas]
nas            ansible_host=10.0.60.10  ansible_user=ansible

# -----------------------------------------------------------------------------
# GROUP VARIABLES INHERITANCE
# -----------------------------------------------------------------------------
[linux:children]
management
sift_remnux
tsurugi
zeek_suricata
velociraptor
cape
inetsim
thehive
misp
opencti
shuffle
sof_elk
nas
android_forensics
crypto_tracing

[windows:children]
flare_vm
ms_cloud

[all:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_private_key_file=~/.ssh/ecrime_homelab_ed25519
# Override per host if needed

[linux:vars]
ansible_user=ansible

[windows:vars]
ansible_connection=winrm
ansible_winrm_transport=ntlm
ansible_port=5986
