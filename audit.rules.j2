# =============================================================================
# Auditd Rules — ECrime Homelab
# Managed by Ansible — DO NOT edit manually
# Aligned with CIS Benchmark + DFIR forensic requirements
# =============================================================================

# Delete all existing rules
-D

# Buffer size (increase if losing events under heavy load)
-b 8192

# Failure mode: 1=log, 2=panic
-f 1

# ── Identity and Authentication ───────────────────────────────────────────────
-w /etc/passwd        -p wa -k identity
-w /etc/shadow        -p wa -k identity
-w /etc/group         -p wa -k identity
-w /etc/gshadow       -p wa -k identity
-w /etc/sudoers       -p wa -k privilege_escalation
-w /etc/sudoers.d/    -p wa -k privilege_escalation
-w /etc/pam.d/        -p wa -k pam

# ── Login and session events ──────────────────────────────────────────────────
-w /var/log/faillog   -p wa -k auth
-w /var/log/lastlog   -p wa -k auth
-w /var/run/utmp      -p wa -k session
-w /var/log/wtmp      -p wa -k session
-w /var/log/btmp      -p wa -k session

# ── SSH ───────────────────────────────────────────────────────────────────────
-w /etc/ssh/sshd_config  -p wa -k sshd_config

# ── Network configuration changes ────────────────────────────────────────────
-w /etc/hosts                   -p wa -k network
-w /etc/network/                -p wa -k network
-w /etc/resolv.conf             -p wa -k network
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k network

# ── System calls — privilege escalation ──────────────────────────────────────
-a always,exit -F arch=b64 -S setuid  -F a0=0 -F exe=/usr/bin/su     -k priv_esc
-a always,exit -F arch=b64 -S setresuid -F a0=0 -F exe=/usr/bin/sudo -k priv_esc

# ── Execution tracking ────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S execve -k exec
-a always,exit -F arch=b32 -S execve -k exec

# ── File deletion ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -k delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat -k delete

# ── Module loading / kernel tampering ────────────────────────────────────────
-w /sbin/insmod   -p x -k modules
-w /sbin/rmmod    -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module -S delete_module -k modules

# ── Evidence NAS — any write attempt is an anomaly ───────────────────────────
# (Applied only on hosts that mount the evidence NAS)
# -w /mnt/evidence/ -p wa -k evidence_tamper

# ── Audit log integrity ───────────────────────────────────────────────────────
-w /var/log/audit/    -p wa -k audit_logs
-w /etc/audit/        -p wa -k audit_config
-w /etc/libaudit.conf -p wa -k audit_config
-w /etc/audisp/       -p wa -k audit_config

# ── Immutable (lock rules) — comment out during initial setup ─────────────────
# -e 2
