---
# .ansible-lint — ECrime Homelab
profile: production

exclude_paths:
  - ansible/roles/common/templates/
  - ansible/roles/velociraptor/templates/
  - .cache/

skip_list:
  - yaml[line-length]        # Long task names acceptable for clarity
  - name[casing]             # Lowercase role prefixes are intentional
  - no-changed-when          # Some commands have create guards instead

warn_list:
  - experimental
  - yaml[truthy]

mock_modules:
  - community.general.ufw
  - community.general.zfs
  - community.general.modprobe
  - community.general.capabilities
  - community.postgresql.postgresql_user
  - community.postgresql.postgresql_db
  - community.docker.docker_compose
  - community.libvirt.virt_net
  - ansible.posix.sysctl
  - ansible.posix.authorized_key
  - ansible.posix.mount
  - ansible.windows.win_shell
  - ansible.windows.win_get_url
  - ansible.windows.win_template
  - ansible.windows.win_service
  - ansible.windows.win_file
  - ansible.windows.win_firewall
  - chocolatey.chocolatey.win_chocolatey
  - community.windows.win_unzip
